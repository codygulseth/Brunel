# Copy to .env only when an entry point adds dotenv loading.
BRUNEL_ENVIRONMENT=development
BRUNEL_DATA_DIRECTORY=data
BRUNEL_LOG_LEVEL=INFO
BRUNEL_LOG_JSON=false
BRUNEL_MODEL_PROVIDER=disabled
# BRUNEL_MODEL_NAME=
# BRUNEL_MODEL_BASE_URL=
# BRUNEL_MODEL_API_KEY=
BRUNEL_MODEL_TEMPERATURE=0.1
BRUNEL_STRUCTURED_OUTPUT_RETRY_LIMIT=1
BRUNEL_RETRIEVAL_TOP_K=5
BRUNEL_MINIMUM_RELEVANCE=0.08
BRUNEL_CITATION_EXCERPT_LENGTH=320
BRUNEL_MAXIMUM_EVIDENCE_CHUNKS=8
BRUNEL_ANSWER_PROVIDER=extractive
BRUNEL_REVISION_ALIGNMENT_THRESHOLD=0.55
BRUNEL_REVISION_AMBIGUOUS_THRESHOLD=0.08
BRUNEL_REVISION_MINIMUM_SIMILARITY=0.35
BRUNEL_REVISION_MAXIMUM_BLOCK_SIZE=2000
BRUNEL_REVISION_INCLUDE_FORMATTING=false
BRUNEL_REVISION_MAXIMUM_EXCERPT_LENGTH=500
BRUNEL_REVISION_MINIMUM_SEVERITY=low
BRUNEL_REPORT_OUTPUT_DIRECTORY=reports
BRUNEL_REVISION_RULES_VERSION=construction-rules-v1
